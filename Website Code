<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JukeBox</title>

<!-- Ferdoca Font -->
<link href="https://fonts.cdnfonts.com/css/ferdoca" rel="stylesheet">

<style>

body{
    margin:0;
    background-color:#FEA656;
    color:#FAF3EB;
    font-family:'Ferdoca', sans-serif;
    text-align:center;
}

.container{
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    min-height:100vh;
}

.logo{
    width:200px;
    margin-bottom:20px;
}

.slogan{
    font-size:32px;
    margin-bottom:40px;
}

.download{
    font-size:28px;
    text-decoration:underline;
    color:#FAF3EB;
    margin-bottom:80px;
}

.download:hover{
    opacity:0.8;
}

.newsletter{
    margin-top:auto;
    padding-bottom:60px;
}

input[type="email"]{
    padding:12px;
    border:none;
    border-radius:5px;
    width:250px;
    margin-right:10px;
    font-family:'Ferdoca', sans-serif;
}

button{
    padding:12px 20px;
    border:none;
    border-radius:5px;
    background-color:#FAF3EB;
    color:#FEA656;
    font-family:'Ferdoca', sans-serif;
    cursor:pointer;
}

button:hover{
    opacity:0.8;
}

.socials{
    margin-top:30px;
}

.socials a{
    color:#FAF3EB;
    margin:0 10px;
    text-decoration:none;
    font-size:20px;
}

</style>
</head>

<body>

<div class="container">

<!-- Logo -->
<img src="JB-BANNER-ORANGE.png" class="logo" alt="JukeBox Logo">

<!-- Slogan -->
<div class="slogan">
for music lovers.
</div>

<!-- Download -->
<a class="download" href="#">
DOWNLOAD NOW
</a>

<!-- Newsletter -->
<div class="newsletter">

<h2>Sign up for our newsletter</h2>

<form>
<input type="email" placeholder="Enter your email">
<button type="submit">Subscribe</button>
</form>

<div class="socials">
<p>follow our socials!</p>

<a href="#">LinkedIn</a>
<a href="#">Instagram</a>
<a href="#">TikTok</a>

</div>

</div>

</div>

</body>
</html>
